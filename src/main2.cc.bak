#include <list>

bool gl_debug=true;

template<typename T> class circular_buffer : public std::list<T> {
private:
  size_t max_size;
public:
  circular_buffer():max_size(100) {
  }

  void trim(void) {
    while(this->size()>max_size) {
      this->pop_front();
    }
  }
};

circular_buffer<std::string> output_buf;

void dump_output_buffer(void) {
  for(auto astr:output_buf) {
    std::cout << astr;
  }
}

void dump_and_exit(void) {
  dump_output_buffer();
  exit(1);
}


class op_fetch {
public:
  qkz8080_uint8 op;
  qkz8080_uint16 addr;
  op_fetch():op(0),addr(0) {
  }
  op_fetch(qkz8080_uint8 aop,
	   qkz8080_uint16 aaddr):op(aop),addr(aaddr) {
  }

};
  
class debug_trace : public qkz8080_trace {
  qkz8080 *cpu;
  std::set<qkz8080_uint8> reg8s;
  std::set<qkz8080_uint8> reg16s;
  std::string comment_str;
  std::string op_str;
  std::vector<op_fetch> ops;

 public:
  debug_trace(qkz8080 *acpu);
  virtual void comment(const char *fmt,...) {
#define COM_BUF_SIZE (100)
    char com_buf[COM_BUF_SIZE];
    va_list ap;
    va_start(ap, fmt);
    vsnprintf(com_buf,COM_BUF_SIZE-1, fmt, ap);
    va_end(ap);
    comment_str=std::string(com_buf);
  }

  virtual void asm_op(const char *fmt,...) {
#define OPBUF_SIZE (100)
    char op_buf[OPBUF_SIZE];
    va_list ap;
    va_start(ap, fmt);
    vsnprintf(op_buf,OPBUF_SIZE-1, fmt, ap);
    va_end(ap);
    op_str=std::string(op_buf);
  }
  
  virtual void flush(void) {
    if(op_str.size()>0) {
      std::stringstream ss;
      
      ss
	<< op_str
	<< " "
	;
      for(int i=0;i<ops.size();i++) {
	op_fetch afetch(ops[i]);
	int addr(afetch.addr);
	ss
	  << std::hex
	  << addr
	  << "["
	  << std::hex
	  << int(afetch.op)
	  << std::dec
	  << "] ";
      }

      if(comment_str.size()>0) {
	ss
	  << " ;"
	  << comment_str;
      }

      for(auto areg16: reg16s) {
	ss
	  << cpu->name_reg16(areg16) << "=" << std::hex << int(cpu->get_reg16(areg16)) << " ";
      }

      for(auto areg8: reg8s) {
	ss
	  << cpu->name_reg8(areg8) << "=" << std::hex << int(cpu->get_reg8(areg8));
	if(areg8 == cpu->reg_A) {
	  qkz8080_uint8 flags(cpu->regs.get_flags());
	  ss << ":";
	  if((flags&qkz8080_cpu_flags::qkz8080_cpu_flags::CY)!=0)
	    ss << "C";
	  if((flags&qkz8080_cpu_flags::qkz8080_cpu_flags::S)!=0)
	    ss << "S";
	  if((flags&qkz8080_cpu_flags::qkz8080_cpu_flags::P)!=0)
	    ss << "P";
	  if((flags&qkz8080_cpu_flags::qkz8080_cpu_flags::Z)!=0)
	    ss << "Z";
	  if((flags&qkz8080_cpu_flags::qkz8080_cpu_flags::AC)!=0)
	    ss << "H";
	}
	ss << " ";
      }
      ss
	<< std::endl
	;
      std::string output_str(ss.str());
      output_buf.push_back(output_str);
      output_buf.trim();
    }
    op_str=std::string("");
    comment_str=std::string("");
    reg8s.clear();
    reg16s.clear();
    ops.clear();
  }

  virtual void fetch(qkz8080_uint8 opstream_byte,qkz8080_uint16 pc) {
    op_fetch afetch(opstream_byte,pc);
    ops.push_back(afetch);
  }

  virtual void add_reg8(qkz8080_uint8 areg) {
    reg8s.insert(areg);
  }

  virtual void add_reg16(qkz8080_uint16 areg) {
    reg16s.insert(areg);
  }
};

debug_trace::debug_trace(qkz8080 *acpu) {
  cpu=acpu;
};

bool cpm_emulate(qkz8080 *cpu) {
  const qkz8080_uint16 pc=cpu->regs.PC.get_pair16();

  // jmp 0 to exit
  if(pc==0)  {
    fprintf(stderr,"exit jmp 0000\n");
    exit(0);
  }

  // bdos call?
  if(pc==5) {
    {
      // simulate RET from bdos
      qkz8080_uint16 addr(cpu->pop_word());
      cpu->regs.PC.set_pair16(addr);
    }

    qkz8080_uint8 regc(cpu->get_reg8(qkz8080::reg_C));
    if(regc==9) {		// print string?
      qkz8080_uint16 addr(cpu->get_reg16(qkz8080::regp_DE));
      std::string print_me;
      while(1) {
	char ch=cpu->mem.fetch_mem(addr);
	if(ch == '$')
	  break;
	addr++;
	print_me.push_back(char(ch));
      };
      std::cout << print_me;
      return true;
    }

    if(regc==12) {
      // cpm version
      const int cpm_version=0x22;
      cpu->set_reg8(cpm_version,qkz8080::reg_A);
      cpu->set_reg8(cpm_version,qkz8080::reg_L);
      // cpm type
      const int cpm_type=0;
      cpu->set_reg8(cpm_type,qkz8080::reg_B);
      cpu->set_reg8(cpm_type,qkz8080::reg_H);
      return true;
    } 

    // print character
    if(regc==2) {
      qkz8080_uint8 ch(cpu->get_reg8(qkz8080::reg_E));
      ch&0x7f;
      std::cout << ch;
      return true;
    }
    
    {
      fprintf(stderr,"unimplemented bdos call=%d\n",int(regc));
      dump_and_exit();
    }
  }
  return false;
}

// memory callbacks
#define MEMORY_SIZE 0x10000
static uint8_t memory[MEMORY_SIZE];
static bool test_finished = 0;

static uint8_t rb(void* userdata, uint16_t addr) {
  return memory[addr];
}

static void wb(void* userdata, uint16_t addr, uint8_t val) {
  memory[addr] = val;
}

static uint8_t port_in(void* userdata, uint8_t port) {
  return 0x00;
}

static void port_out(void* userdata, uint8_t port, uint8_t value) {
  i8080* const c = (i8080*) userdata;

  if (port == 0) {
    test_finished = 1;
  } else if (port == 1) {
    uint8_t operation = c->c;

    if (operation == 2) { // print a character stored in E
      printf("%c", c->e);
    } else if (operation == 9) { // print from memory at (DE) until '$' char
      uint16_t addr = (c->d << 8) | c->e;
      do {
        printf("%c", rb(c, addr++));
      } while (rb(c, addr) != '$');
    }
  }
}

static int is_non0(qkz8080_uint8 abyte) {
  if(abyte!=0)
    return 1;
  return 0;
}

std::string qkz_regs_as_string(qkz8080 *cz) {
  std::stringstream ss;
  qkz8080_uint8 flags8(cz->regs.get_flags());
  ss
    << std::hex << cz->get_reg16(qkz8080::regp_PC) << ";"
    << std::hex << cz->get_reg16(qkz8080::regp_SP) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_A)) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_B)) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_C)) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_D)) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_E)) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_H)) << ";"
    << std::hex << int(cz->get_reg8(qkz8080::reg_L)) << "|"
    << std::hex << is_non0(flags8&qkz8080_cpu_flags::S) << ";"
    << std::hex << is_non0(flags8&qkz8080_cpu_flags::Z) << ";"
    << std::hex << is_non0(flags8&qkz8080_cpu_flags::AC) << ";"
    << std::hex << is_non0(flags8&qkz8080_cpu_flags::P) << ";"
    << std::hex << is_non0(flags8&qkz8080_cpu_flags::CY) << std::endl;
    ;
  return ss.str();
}

std::string cpu_regs_as_string(i8080 *c) {
  std::stringstream ss;
  ss
    << std::hex << c->pc << ";"
    << std::hex << c->sp << ";"
    << std::hex << int(c->a) << ";"
    << std::hex << int(c->b) << ";"
    << std::hex << int(c->c) << ";"
    << std::hex << int(c->d) << ";"
    << std::hex << int(c->e) << ";"
    << std::hex << int(c->h) << ";"
    << std::hex << int(c->l) << "|"
    << std::hex << int(c->sf) << ";"
    << std::hex << int(c->zf) << ";"
    << std::hex << int(c->hf) << ";"
    << std::hex << int(c->pf) << ";"
    << std::hex << int(c->cf) << std::endl;
  return ss.str();
}

extern void i8080_ret(i8080* const c);

static void run_program(const char *file_to_run,
			bool cpm_mode) {

  qkz8080 proc;
  debug_trace deb_trace(&proc);
  proc.set_debug(gl_debug); 
  if(gl_debug) 
    proc.set_trace(&deb_trace);
  
  FILE *code_file(fopen(file_to_run,"rb"));
  if(code_file==0) {
    fprintf(stderr,"open failed");
    exit(1);
  }
  char *code_buf(proc.get_mem()); 
  int start_offset=0;
  if(cpm_mode)
    start_offset=0x100;
  char *load_at(code_buf+start_offset);
  int buf_size=0x10000;
  int did_read(fread(load_at,1,buf_size,code_file));
  fprintf(stderr,"read %d bytes\n",did_read);
  fclose(code_file);

  // start at 100h for cpm
  proc.regs.PC.set_pair16(start_offset);
  // starting stack
  proc.regs.SP.set_pair16(0xfff0);

  i8080 icpu;
  i8080 *c(&icpu);
  i8080_init(c);
  c->userdata = c;
  c->read_byte = rb;
  c->write_byte = wb;
  c->port_in = port_in;
  c->port_out = port_out;
  c->pc=proc.regs.PC.get_pair16();
  c->sp=proc.regs.SP.get_pair16();

  char *raw_mem=proc.mem.get_mem();
  for(unsigned int i=0;i<=0x0ffff;i++) {
    wb(0,i,raw_mem[i]);
  }

  while(1) {
    deb_trace.flush();
    if(cpm_mode && cpm_emulate(&proc))
      continue;
    {
      uint16_t pc(c->pc);
      if(pc==0) {
	std::cout << "8080 exits" << std::endl;
	exit(1);
      }
      if(pc==5) {
	// emulate return from bdos call
	i8080_ret(c);
	uint8_t regxc(c->c);
	if(regxc==9) {
	  // print string the other machine will print it
	  continue;
	}
	if(regxc==2) {
	  // print char
	  continue;
	}
    {
      fprintf(stderr,"unimplemented 8080 bdos call=%d\n",int(regxc));
      exit(1);
    }

      }
    }

    std::string qkz_state(qkz_regs_as_string(&proc)); 
    std::string i8080_state(cpu_regs_as_string(c));
    if(qkz_state!=i8080_state) {
      std::cout
	<< "cpu states differ " << std::endl
	<< "80 " << i8080_state
	<< "qk " << qkz_state;
      dump_and_exit();
	
    }

    bool check_mem(false);
    if(check_mem)
    for(int i=0;i<0x10000;i++) {
	unsigned char ch_c=proc.mem.fetch_mem(i);
	unsigned char ch_8=memory[i];
	if(ch_c!=ch_8) {
	  std::cout
	    << "memory difference at "
	    << std::hex << i
	    << " qcpu=" << std::hex << int(ch_c)
	    << " ch_8=" << std::hex << int(ch_8)
	    << std::endl;
	  dump_and_exit();
	}
    }
    
    proc.execute();
    i8080_step(c);
  }

}

int main(int argc,char **argv) {
  run_program("4kbas40.bin",false);

  run_program("../../8080exm.com",true);

  run_program("test2.com",true);

  run_program("test1.com",true);

  run_program("../../8080pre.com",true);
  run_program("../../8080ex1.com",true);

  run_program("../../ex8080.com",true);
  run_program("../../ddt.com",true);
  run_program("../../mbasic.com",true);
}
