#ifndef I8080_REG_PAIR
#define I8080_REG_PAIR 1
// two 8bit regs
// settable as a 16bit word
// does not depend on compiler/runtime big/little end
// binary bits not portable (as in don't write this raw data to a binary file)

#include "qkz8080_types.h"

class qkz8080_reg_pair {
 protected:
  qkz8080_uint16 dat;
 public:
  qkz8080_reg_pair():
    dat(0) {
  }
  qkz8080_reg_pair(const qkz8080_reg_pair& rp): dat(rp.dat) {
  }
  qkz8080_uint8 get_low(void) const {
    return qkz8080_GET_CLEAN8(dat);
  }
  qkz8080_uint8 get_high(void) const {
    return qkz8080_GET_HIGH8(dat);
  }
  qkz8080_uint16 get_pair16(void) const {
    return dat;
  }
  void set_pair16(qkz8080_uint16 a) {
    dat=a;
  }
  void set_low(qkz8080_uint8 a) {
    set_pair16(qkz8080_MK_INT16(a,get_high()));
  }
  void set_high(qkz8080_uint8 a) {
    set_pair16(qkz8080_MK_INT16(get_low(),a));
  }
  void set_pair(qkz8080_uint8 a,qkz8080_uint8 b) {
    set_low(a);
    set_high(b);
  }
};
#endif
