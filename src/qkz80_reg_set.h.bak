#ifndef I8080_REG_SET
#define I8080_REG_SET

// all of the CPU register for an 8080 emulator

#include "qkz8080_reg_pair.h"

class qkz8080_reg_set {
 public:
  qkz8080_reg_pair AF;
  qkz8080_reg_pair BC;
  qkz8080_reg_pair DE;
  qkz8080_reg_pair HL;
  qkz8080_reg_pair SP;
  qkz8080_reg_pair PC;

  bool condition_code(qkz8080_uint8 a,qkz8080_uint8 cpu_flags) const;
  void set_flags_from_logic8(qkz8080_big_uint a,
			     qkz8080_uint8 new_carry,
			     qkz8080_uint8 new_half_carry);
  void set_flags_from_sum8(qkz8080_big_uint a,qkz8080_uint8 new_half_carry);
  void set_flags_from_sum16(qkz8080_big_uint a);
  void set_flags_from_diff8(qkz8080_big_uint a,qkz8080_uint8 half_carry);
  void set_zspa_from_inr(qkz8080_uint8 a,qkz8080_uint8 half_carry);
  qkz8080_uint8 get_flags(void) const;
  void set_flags(qkz8080_uint8 new_flags);

  void set_carry_from_int(qkz8080_big_uint x);
  qkz8080_uint8 get_carry_as_int(void);
};
#endif
